APP_NAME=Audio Transcriber Backend
APP_ENV=development
API_PREFIX=/api
DEBUG=true
UPLOAD_DIR=uploads
DATABASE_URL=postgresql+psycopg://transcriber:transcriber@localhost:5432/audio_transcriber
ALLOWED_AUDIO_EXTENSIONS=mp3,wav,m4a,webm
ALLOWED_AUDIO_MIME_TYPES=audio/mpeg,audio/wav,audio/x-wav,audio/mp4,audio/webm
MAX_UPLOAD_SIZE_MB=25
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
